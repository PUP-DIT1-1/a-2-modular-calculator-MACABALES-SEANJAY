import java.util.*;
public class Main {

    static Scanner sc=new Scanner(System.in);

    public static void main(String[] args){
        double n1,n2,an;
        char op;



        System.out.println("M O D U L A R  C A L C U L A T O R");

        System.out.print("FIRST NUMBER: ");
        n1= sc.nextDouble();

        System.out.print("OPERATOR: ");
        op=sc.next().charAt(0);

        System.out.print("SECOND NUMBER: ");
        n2= sc.nextDouble();

        switch (op){
            case '+':
                an=add(n1,n2);
                System.out.print(an);
                break;

            case '-':
                an=minus(n1,n2);
                System.out.print(an);
                break;

            case '*':
                an=times(n1,n2);
                System.out.print(an);
                break;

            case '/':
                an=divide(n1,n2);
                System.out.print(an);

                break;

            default:
                System.out.println("ERROR, THIS OPERATION IS INVALID");
        }

    }
    public static double add(double n1, double n2){
        return n1+n2;}

    public static double minus(double n1, double n2){
        return n1-n2;}

    public static double times(double n1, double n2){
        return n1*n2;}

    public static double divide(double n1, double n2){
        return n1/n2;}
}
